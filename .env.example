# ============================================================
# miaopin-service 环境变量模板
# 用法：cp .env.example .env 后填空值；标「配置台可热改」的项也可在
#      http://ai-hr.juzibot.com/admin 页面里改（config.json 覆盖优先，回退本文件）
# 密钥类（*_SECRET / *_TOKEN）请填后勿提交，.env 本体已被 gitignore
# ============================================================

# ---------- 服务级基建（改这些要重启，配置台不管）----------
PORT=3000

# 飞书自建应用（服务身份：读写多维表、建面试日程、群通知）
FEISHU_APP_ID=cli_aad38fd84da1dbb3
FEISHU_APP_SECRET=            # 开放平台→凭证与基础信息，勿进代码
FEISHU_BASE=https://open.feishu.cn
FEISHU_ENCRYPT_KEY=          # 事件订阅加密串（未开事件加密可留空）

# 秒懂（AI 画布 / 意图识别）
INSIGHT_BASE=https://test-aa-insight.ddregion.com/api
INSIGHT_ORG=aab99626-d471-4d3e-966b-2b447b909bf8
INSIGHT_TOKEN=               # 秒懂开放接口 token

# 秒回（招聘企微 OpenAPI）
MIAOHUI_OPENAPI_BASE=https://test-aa-api.ddregion.com

# 状态机存储（触达编排幂等 + 状态；docker network: aihr-net）
MONGO_URI=mongodb://mongo:27017/aihr
REDIS_URL=redis://redis:6379

# ---------- 以下均「配置台可热改」，此处仅作首启兜底 ----------

# 两张多维表
AIHR_APP_TOKEN=DAPLb6IJwan1EOsclt8c3klEnPb
AIHR_TABLE_ID=tblW6QconCWm5HQP
PROG_APP_TOKEN=WzXpbCdYgaZDk0s7dSiczy20nnc
PROG_TABLE_ID=tblVRrAmRPtQsY1L

# 秒懂两个 bot + 模型
INTENT_BOT_ID=               # 意图识别 bot
CHAT_BOT_ID=                 # 对话 bot
MODEL=                       # 空=用画布默认模型

# 触达运行参数
DRY_RUN=true                 # true=演练不真发；联调/上线改 false
INTERVIEW_LINK=              # 兜底面试链接（正常由建日程后的飞书视频会议生成）
HELLO_MSG=你好，我是句子互动招聘助理，看到你投递的岗位，想跟你约一次面试~
POLL_INTERVAL_SEC=60

# 秒回招聘企微
MIAOHUI_GROUP_TOKEN=         # 小组级 token（加好友/发消息鉴权 + 回调校验）
MIAOHUI_CORP_ID=ww5ecc1acd5dce6e9d
MIAOHUI_BOT_USERID=jiahongjia
FEISHU_BOT_NAME=秒聘         # 群里 @ 它触发运维指令

# HR 通知 & 面试日程
HR_EMAIL=                    # HR 飞书邮箱：候选人约上后建面试日程并邀 HR 参会
HR_NOTIFY_CHAT=              # 触达失败/需人工时通知的飞书会话 chat_id(oc_...)
